<!DOCTYPE html>
<html>
<head>
<title>Image Gallery</title>

<style>
body{
font-family: Arial;
background:#ffe6f0;
text-align:center;
}

h1{
background:#ff66b2;
color:white;
padding:15px;
}

.gallery{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:15px;
padding:20px;
}

.gallery img{
width:100%;
border-radius:10px;
cursor:pointer;
transition:0.3s;
}

.gallery img:hover{
transform:scale(1.05);
}

#lightbox{
display:none;
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.8);
justify-content:center;
align-items:center;
}

#lightbox img{
max-width:80%;
border-radius:10px;
}
</style>
</head>

<body>

<h1>My Image Gallery</h1>

<div class="gallery">
<img src="https://picsum.photos/300?1" onclick="openImg(this.src)">
<img src="https://picsum.photos/300?2" onclick="openImg(this.src)">
<img src="https://picsum.photos/300?3" onclick="openImg(this.src)">
<img src="https://picsum.photos/300?4" onclick="openImg(this.src)">
<img src="https://picsum.photos/300?5" onclick="openImg(this.src)">
<img src="https://picsum.photos/300?6" onclick="openImg(this.src)">
<img src="https://picsum.photos/300?7" onclick="openImg(this.src)">
<img src="https://picsum.photos/300?8" onclick="openImg(this.src)">
<img src="https://picsum.photos/300?9" onclick="openImg(this.src)">
</div>

<div id="lightbox" onclick="closeImg()">
<img id="lightbox-img">
</div>

<script>
function openImg(src){
document.getElementById("lightbox").style.display="flex";
document.getElementById("lightbox-img").src=src;
}

function closeImg(){
document.getElementById("lightbox").style.display="none";
}
</script>

</body>
</html>
