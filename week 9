<!DOCTYPE html>
<html>
<head>
<title>Ultimate Weather Dashboard</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI;
}

body{
height:100vh;
overflow:hidden;
background:linear-gradient(-45deg,#4facfe,#00f2fe,#43e97b,#38f9d7);
background-size:400% 400%;
animation:bgmove 10s infinite alternate;
color:white;
}

@keyframes bgmove{
0%{background-position:0% 50%;}
100%{background-position:100% 50%;}
}

.dark{
background:linear-gradient(-45deg,#141e30,#243b55,#000);
}

/* NAVBAR */

.navbar{
position:absolute;
top:0;
width:100%;
padding:15px;
text-align:center;
background:rgba(255,255,255,0.1);
backdrop-filter:blur(10px);
font-size:24px;
font-weight:bold;
}

/* CLOUDS */

.cloud{
position:absolute;
top:80px;
font-size:60px;
opacity:0.4;
animation:cloudmove 40s linear infinite;
}

@keyframes cloudmove{
0%{left:-10%;}
100%{left:110%;}
}

/* MAIN */

.container{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
text-align:center;
}

.clock{
font-size:22px;
margin-bottom:15px;
}

.buttons button{
padding:10px 20px;
margin:5px;
border:none;
border-radius:20px;
cursor:pointer;
font-weight:bold;
}

.card{
width:320px;
padding:30px;
margin:auto;
border-radius:20px;
background:rgba(255,255,255,0.15);
backdrop-filter:blur(12px);
border:1px solid rgba(255,255,255,0.3);
box-shadow:0 10px 30px rgba(0,0,0,0.3);
transition:0.4s;
}

.card:hover{
transform:scale(1.05);
}

.city{
font-size:26px;
font-weight:bold;
}

.icon{
font-size:70px;
margin:15px;
}

.temp{
font-size:50px;
font-weight:bold;
}

.condition{
font-size:20px;
margin-bottom:10px;
}

.details{
font-size:14px;
}

.toggle button{
margin-top:15px;
padding:8px 18px;
border:none;
border-radius:20px;
background:black;
color:white;
cursor:pointer;
}

/* RAIN */

.rain{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
pointer-events:none;
display:none;
}

.drop{
position:absolute;
width:2px;
height:15px;
background:white;
opacity:0.5;
animation:rainfall 1s linear infinite;
}

@keyframes rainfall{
0%{transform:translateY(-100px);}
100%{transform:translateY(100vh);}
}

</style>
</head>

<body>

<div class="navbar">
🌦️ Ultimate Weather Dashboard
</div>

<div class="cloud">☁️</div>

<div class="rain" id="rain"></div>

<div class="container">

<div class="clock" id="clock"></div>

<div class="buttons">
<button onclick="showWeather('himachal')">Himachal</button>
<button onclick="showWeather('kerala')">Kerala</button>
<button onclick="showWeather('rajasthan')">Rajasthan</button>
</div>

<br>

<div class="card">

<div class="city" id="city">Himachal</div>

<div class="icon" id="icon">
<i class="fas fa-snowflake"></i>
</div>

<div class="temp" id="temp">15°C</div>

<div class="condition" id="condition">Snowy</div>

<div class="details" id="details">
Humidity:60% | Wind:8 km/h
</div>

</div>

<div class="toggle">
<button onclick="toggleMode()">Day / Night</button>
</div>

</div>

<script>

/* WEATHER SWITCH */

function showWeather(city){

let rain=document.getElementById("rain")
rain.style.display="none"

if(city==="himachal"){
city="Himachal"
temp="15°C"
cond="Snowy"
det="Humidity:60% | Wind:8km/h"
icon='<i class="fas fa-snowflake"></i>'
}

if(city==="kerala"){
city="Kerala"
temp="28°C"
cond="Rainy"
det="Humidity:85% | Wind:12km/h"
icon='<i class="fas fa-cloud-rain"></i>'
rain.style.display="block"
}

if(city==="rajasthan"){
city="Rajasthan"
temp="35°C"
cond="Hot & Sunny"
det="Humidity:20% | Wind:10km/h"
icon='<i class="fas fa-sun"></i>'
}

document.getElementById("city").innerHTML=city
document.getElementById("temp").innerHTML=temp
document.getElementById("condition").innerHTML=cond
document.getElementById("details").innerHTML=det
document.getElementById("icon").innerHTML=icon

}

/* DAY NIGHT */

function toggleMode(){
document.body.classList.toggle("dark")
}

/* CLOCK */

function updateClock(){
let now=new Date()
let time=now.toLocaleTimeString()
document.getElementById("clock").innerHTML="🕒 "+time
}

setInterval(updateClock,1000)

/* RAIN GENERATOR */

let rain=document.getElementById("rain")

for(let i=0;i<100;i++){

let drop=document.createElement("div")
drop.classList.add("drop")
drop.style.left=Math.random()*100+"%"
drop.style.animationDuration=(Math.random()*0.5+0.5)+"s"

rain.appendChild(drop)

}

</script>

</body>
</html>
