<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Browser History using Stack</title>
<style>
  body {
    font-family: Arial;
    margin: 0;
    background: linear-gradient(to right, #d7ccc8, #8d6e63);
  }

  header {
    background: #5d4037;
    color: white;
    padding: 15px;
    text-align: center;
    font-size: 22px;
  }

  .container {
    padding: 20px;
  }

  .box {
    background: #efebe9;
    padding: 15px;
    border-radius: 10px;
    margin-bottom: 15px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  input {
    padding: 8px;
    width: 70%;
    border-radius: 5px;
    border: 1px solid #a1887f;
  }

  button {
    padding: 8px 12px;
    margin: 5px;
    border: none;
    border-radius: 5px;
    background: #8d6e63;
    color: white;
    cursor: pointer;
  }

  button:hover {
    background: #5d4037;
  }

  h3 {
    color: #5d4037;
  }
</style>
</head>
<body>

<header>
  Browser History (Stack Implementation)
</header>

<div class="container">

<div class="box">
  <h3>Visit New Page</h3>
  <input type="text" id="url" placeholder="Enter URL">
  <button onclick="visitPage()">Visit</button>
</div>

<div class="box">
  <button onclick="goBack()">⬅ Back</button>
  <button onclick="goForward()">Forward ➡</button>
</div>

<div class="box">
  <h3>Current Page:</h3>
  <p id="current">None</p>
</div>

<div class="box">
  <h3>Back Stack:</h3>
  <p id="backStack"></p>
</div>

<div class="box">
  <h3>Forward Stack:</h3>
  <p id="forwardStack"></p>
</div>

</div>

<script>
let backStack = [];
let forwardStack = [];
let currentPage = null;

function visitPage() {
  const url = document.getElementById('url').value;
  if (!url) return;

  if (currentPage !== null) {
    backStack.push(currentPage);
  }

  currentPage = url;
  forwardStack = [];

  updateUI();
}

function goBack() {
  if (backStack.length === 0) return;

  forwardStack.push(currentPage);
  currentPage = backStack.pop();

  updateUI();
}

function goForward() {
  if (forwardStack.length === 0) return;

  backStack.push(currentPage);
  currentPage = forwardStack.pop();

  updateUI();
}

function updateUI() {
  document.getElementById('current').innerText = currentPage || 'None';
  document.getElementById('backStack').innerText = backStack.join(' → ');
  document.getElementById('forwardStack').innerText = forwardStack.join(' → ');
}
</script>

</body>
</html>
